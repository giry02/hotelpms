// dashboard.schema.json – JSON Schema for dashboard data
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dashboard",
  "type": "object",
  "required": ["weekData", "monthData", "svcData"],
  "properties": {
    "weekData": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["day", "label", "occ", "prev"],
        "properties": {
          "day": { "type": "string" },
          "label": { "type": "string" },
          "occ": { "type": "integer" },
          "prev": { "type": "integer" }
        },
        "additionalProperties": false
      }
    },
    "monthData": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["day", "occ"],
        "properties": {
          "day": { "type": "string" },
          "occ": { "type": "integer" }
        },
        "additionalProperties": false
      }
    },
    "svcData": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "val", "pct", "icon", "color"],
        "properties": {
          "name": { "type": "string" },
          "val": { "type": "integer" },
          "pct": { "type": "integer" },
          "icon": { "type": "string" },
          "color": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
